# DuckDB
DUCKDB_PATH=data/processed/fraud.duckdb

# LLM provider (Fase 3) - usa Ollama local por defecto
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Alternativas free tier (opcional, si no usas Ollama)
GROQ_API_KEY=
GEMINI_API_KEY=

# Vector store (Fase 3)
CHROMA_PERSIST_DIR=data/processed/chroma
